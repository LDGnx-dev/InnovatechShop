---
const { title } = Astro.props;
// Aquí después recuperaremos el rol del usuario para el "Dev Panel"
const userRole = "dev"; 
---

<div class="admin-container">
  <aside class="sidebar">
    <div class="brand">
      <span class="pixel-logo">PX</span> Innovatech
    </div>
    
    <nav class="menu">
      <a href="/admin" class="nav-link"> Dashboard</a>
      <a href="/admin/inventory" class="nav-link"> Inventario</a>
      <a href="/admin/users" class="nav-link"> Usuarios</a>
      <a href="/admin/config" class="nav-link"> Configuración</a>
      
      {userRole === "dev" && (
        <div class="dev-section">
          <p class="section-label">System</p>
          <a href="/admin/dev" class="nav-link dev"> Dev Panel</a>
        </div>
      )}
    </nav>

    <div class="user-card">
      <div class="avatar">P</div>
      <div class="info">
        <span class="name">Pixel</span>
        <span class="role">{userRole.toUpperCase()}</span>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="top-bar">
      <h2>{title}</h2>
    </header>
    <section class="page-body">
      <slot />
    </section>
  </main>
</div>

<style is:global>
  :root {
    --bg-dark: #09090b;
    --panel-dark: #121214;
    --accent: #a855f7; /* Tu púrpura preferido */
    --text-main: #f4f4f5;
    --text-muted: #a1a1aa;
    --border: #27272a;
  }

  body { background: var(--bg-dark); color: var(--text-main); margin: 0; font-family: sans-serif; }

  .admin-container { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }

  .sidebar { 
    background: var(--panel-dark); 
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column; padding: 1.5rem;
  }

  .brand { font-weight: bold; font-size: 1.2rem; margin-bottom: 2rem; color: var(--accent); }
  
  .menu { flex-grow: 1; display: flex; flex-direction: column; gap: 0.5rem; }
  
  .nav-link {
    color: var(--text-muted); text-decoration: none; padding: 0.8rem 1rem;
    border-radius: 8px; transition: all 0.2s; display: block;
  }

  .nav-link:hover { background: #1e1e22; color: var(--accent); }
  
  .dev-section { margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1rem; }
  .section-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem; }
  .nav-link.dev { color: #f43f5e; } /* Rojo suave para indicar peligro/sistema */

  .main-content { padding: 0; }
  .top-bar { padding: 1rem 2rem; border-bottom: 1px solid var(--border); background: var(--panel-dark); }
  .page-body { padding: 2rem; }

  @media (max-width: 768px) {
    .admin-container { grid-template-columns: 1fr; }
    .sidebar { display: none; } /* Aquí podrías implementar un menú hamburguesa */
  }
</style>