---
import AdminLayout from './AdminLayout.astro';
// Simulamos datos de tu otra DB de negocios
const metrics = [
  { label: "Ventas Netas", value: "$12,450", trend: "+12%" },
  { label: "Productos en Stock", value: "142", trend: "Estable" },
  { label: "Usuarios Activos", value: "8", trend: "+2" }
];
---

<AdminLayout title="Dashboard de Negocio">
  <div class="stats-grid">
    {metrics.map(m => (
      <div class="card">
        <span class="label">{m.label}</span>
        <div class="value">{m.value}</div>
        <span class="trend">{m.trend}</span>
      </div>
    ))}
  </div>

  <div class="recent-activity">
    <h3>Actividad Reciente</h3>
    <p class="muted">Conectando con la base de datos de auditoría...</p>
  </div>
</AdminLayout>

<style>
  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .card { 
    background: var(--panel-dark); padding: 1.5rem; border: 1px solid var(--border); 
    border-radius: 12px; transition: transform 0.2s;
  }
  .card:hover { transform: translateY(-5px); border-color: var(--accent); }
  .label { color: var(--text-muted); font-size: 0.9rem; }
  .value { font-size: 1.8rem; font-weight: bold; margin: 0.5rem 0; }
  .trend { color: #10b981; font-size: 0.8rem; }
  .recent-activity { margin-top: 3rem; background: var(--panel-dark); padding: 1.5rem; border-radius: 12px; }
  .muted { color: var(--text-muted); }
</style>