---
import Layout from '../../layouts/Layout.astro';
// Aquí luego validaremos la sesión para que nadie más entre
---

<Layout title="Innovatech | Admin Dashboard">
  <main class="admin-container">
    <aside class="sidebar">
      <div class="logo">
        <h2>G-<span>Lyfe</span></h2>
        <p>Admin Panel</p>
      </div>
      <nav>
        <a href="/admin" class="active">Dashboard</a>
        <a href="/admin/productos">Productos</a>
        <a href="/admin/promociones">Promociones</a>
        <a href="/admin/config">Configuración</a>
      </nav>
      <div class="user-info">
        <span>Pixel</span>
        <a href="/">Salir</a>
      </div>
    </aside>

    <section class="content">
      <header>
        <h1>Bienvenido de nuevo, <span>Pixel</span></h1>
        <p>Estado del sistema: <span class="status-online">Conectado a MongoDB</span></p>
      </header>

      <div class="stats-grid">
        <div class="stat-card">
          <h3>Total Productos</h3>
          <p class="number">--</p>
          <span>En inventario</span>
        </div>
        <div class="stat-card">
          <h3>Tags Activos</h3>
          <p class="number">8</p>
          <span>Categorías</span>
        </div>
        <div class="stat-card">
          <h3>Ofertas Globales</h3>
          <p class="number">2</p>
          <span>Aplicadas por tag</span>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .admin-container {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
    background: var(--bg-page);
    color: var(--text-base);
  }

  /* Sidebar con efecto Glass */
  .sidebar {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border-right: 1px solid var(--glass-border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .logo h2 { font-weight: 800; letter-spacing: -1px; }
  .logo span { color: var(--primary); }

  nav { display: flex; flex-direction: column; gap: 1rem; margin-top: 3rem; }
  
  nav a {
    text-decoration: none;
    color: var(--text-base);
    padding: 1rem;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  nav a:hover, nav a.active {
    background: rgba(168, 85, 247, 0.15);
    color: var(--primary);
    padding-left: 1.5rem;
  }

  /* Contenido */
  .content { padding: 4rem; }
  
  h1 span { color: var(--primary); }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .stat-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    padding: 2rem;
    border-radius: 20px;
    text-align: center;
  }

  .number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--primary);
    margin: 0.5rem 0;
  }

  .status-online { color: #10b981; font-weight: bold; }
</style>