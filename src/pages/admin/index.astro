---
import AdminLayout from './AdminLayout.astro';
// Aquí podrías verificar el rol de la sesión antes de renderizar
---

<AdminLayout title="Panel Dev">
  <header class="page-header">
    <h1>System Status</h1>
    <p>Bienvenido de vuelta, LDGnx.</p>
  </header>

  <section class="dev-terminal">
    <div class="terminal-header">
      <div class="dots"><span></span><span></span><span></span></div>
      <span class="title">zsh — innovatech-core</span>
    </div>
    <div class="terminal-body" id="terminal-output">
      <div class="line">LDGnx@innovatech:~$ system --check</div>
      <div class="line success">Checking database connection... OK</div>
      <div class="line success">Auth service... ACTIVE</div>
      <div class="line">LDGnx@innovatech:~$ <span class="cursor">_</span></div>
    </div>
    <div class="terminal-input-area">
      <span>➜</span>
      <input type="text" id="command-input" placeholder="Escribe un comando (ping, status, clear)..." autofocus />
    </div>
  </section>
</AdminLayout>

<style>
  .dev-terminal {
    background: #000;
    border-radius: 12px;
    border: 1px solid #333;
    overflow: hidden;
    font-family: 'Fira Code', 'Courier New', monospace;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .terminal-header {
    background: #1a1a1a;
    padding: 10px 15px;
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .dots { display: flex; gap: 6px; }
  .dots span { width: 10px; height: 10px; border-radius: 50%; background: #333; }
  .dots span:nth-child(1) { background: #ff5f56; }

  .terminal-body {
    padding: 20px;
    height: 300px;
    overflow-y: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .success { color: #4ade80; }
  .line { margin-bottom: 5px; }

  .terminal-input-area {
    display: flex;
    padding: 10px 20px;
    background: #050505;
    border-top: 1px solid #222;
    align-items: center;
    gap: 10px;
  }

  input {
    background: transparent;
    border: none;
    color: var(--accent);
    flex: 1;
    outline: none;
    font-family: inherit;
  }
</style>

<script>
  const input = document.getElementById('command-input') as HTMLInputElement;
  const output = document.getElementById('terminal-output');

  input?.addEventListener('keypress', async (e) => {
    if (e.key === 'Enter') {
      const cmd = input.value.toLowerCase();
      input.value = '';
      
      // Crear nueva línea de comando
      const cmdLine = document.createElement('div');
      cmdLine.className = 'line';
      cmdLine.innerHTML = `LDGnx@innovatech:~$ ${cmd}`;
      output?.appendChild(cmdLine);

      if (cmd === 'ping') {
        const res = await fetch('/api/dev/ping');
        const data = await res.json();
        const responseLine = document.createElement('div');
        responseLine.className = 'line success';
        responseLine.innerText = `[DB] Pong! ${data.message}`;
        output?.appendChild(responseLine);
      }
      
      if (cmd === 'clear') output!.innerHTML = '';

      output!.scrollTop = output!.scrollHeight;

      if (cmd.startsWith('useradd')) {
        const [_, email, alias] = cmd.split(' '); 
        const res = await fetch('/api/dev/useradd', {
        method: 'POST',
        body: JSON.stringify({ email, alias, name: alias })
      });
        const data = await res.json();
      // ... imprimir data.message en la terminal
      }
    }
  });
</script>