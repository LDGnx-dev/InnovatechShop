---
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="../public/favicon.svg" />
</head>
<body>
    <div id="bg-canvas" style="position: fixed; inset: 0; z-index: -1; opacity: 0.3; pointer-events: none;"></div>
    
    <slot />

    <script>
        // Configuración inicial de fondo y tema
        const bg = document.getElementById('bg-canvas');
        if (bg) bg.style.backgroundImage = "url('https://g-lyfe-api.vercel.app/api/bg.svg?color=a855f7&w=120&h=60')";
        
        const savedTheme = localStorage.getItem('theme') || 'dark';
        document.body.setAttribute('data-theme', savedTheme);
    </script>
</body>
</html>